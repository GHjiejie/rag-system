OPENAI_API_KEY="replace-with-your-api-key"
OPENAI_BASE_URL="https://gmncode.cn/v1"
OPENAI_MODEL="gpt-5.4"
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_EMBEDDING_MODEL="bge-m3"

COLLECTION_NAME="jiejie_test_v2"
CHROMA_PERSIST_DIR="./chroma_data"
CHUNK_SIZE="500"
CHUNK_OVERLAP="50"

RERANK_ENABLED="true"
RERANK_MODEL_NAME="BAAI/bge-reranker-v2-m3"
RERANK_DEVICE="cpu"
RERANK_USE_FP16="false"
RETRIEVAL_TOP_K="6"
RERANK_TOP_N="3"
RERANK_BATCH_SIZE="32"
# 可选。不设置表示仅按分数排序，不做阈值过滤
RERANK_SCORE_THRESHOLD=""

MINIO_ACCESS_KEY="replace-with-your-minio-access-key"
MINIO_SECRET_KEY="replace-with-your-minio-secret-key"
